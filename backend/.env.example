# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── ENV ───────────────────────────────────────────────────────────────────
NODE_ENV=

# ─── PostgreSQL (Prisma) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/live_housie?schema=public

# ─── Redis ────────────────────────────────────────────────────────────────────
# Use REDIS_URL for a full connection string, or REDIS_HOST + REDIS_PORT
# REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-access-token-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── Payment Gateway (placeholder) ───────────────────────────────────────────
PAYMENT_GATEWAY_URL=https://api.sandbox.payment-provider.com
PAYMENT_GATEWAY_KEY=your-payment-gateway-key

# ─── Janus WebRTC Server ─────────────────────────────────────────────────────
JANUS_URL=http://localhost:8088/janus
JANUS_ADMIN_SECRET=your-janus-admin-secret

